{
  "easy downloadGlmOCRAndLoadModel": {
    "display_name": "GLM-OCR 模型加载器",
    "inputs": {
      "model_id": {
        "name": "模型 ID"
      },
      "download_from": {
        "name": "下载来源"
      },
      "attention": {
        "name": "注意力机制"
      },
      "start": {
        "name": "开始",
        "tooltip": "开始加载或下载模型"
      }
    },
    "outputs": {
      "0": {
        "name": "GLM-OCR 模型"
      }
    }
  },
  "easy applyGlmOCR": {
    "display_name": "应用 GLM-OCR",
    "inputs": {
      "glm_ocr_model": {
        "name": "GLM-OCR 模型"
      },
      "image": {
        "name": "输入图像"
      },
      "prompt_template": {
        "name": "提示词模板",
        "tooltip": "用于指导 OCR 过程的提示词"
      },
      "unload_model": {
        "name": "卸载模型",
        "tooltip": "推理后从显存中卸载模型"
      },
      "temperature": {
        "name": "温度"
      },
      "seed": {
        "name": "随机种子"
      },
      "custom_prompt": {
        "name": "自定义提示词",
        "tooltip": "自定义提示词模板（可选，如果提供将覆盖模板）"
      }
    },
    "outputs": {
      "0": {
        "name": "结果",
        "tooltip": "输出结果"
      }
    }
  }
}
